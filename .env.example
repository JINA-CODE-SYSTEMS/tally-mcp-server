# === Required (Cloud/Remote mode only) ===
PASSWORD=                    # OAuth authentication password (required for server.mts)

# === Tally Prime Connection ===
TALLY_HOST=localhost         # Tally Prime XML server hostname
TALLY_PORT=9000              # Tally Prime XML server port
TALLY_DATA_PATH=             # Tally Prime data directory (e.g. C:\Users\Public\TallyPrimeEditLog\data)
TALLY_EXE_PATH=              # Tally Prime executable (default: C:\Program Files\TallyPrime\tally.exe)
TALLY_COMPANY_USER=          # Tally company username (if security is enabled)
TALLY_COMPANY_PASSWORD=      # Tally company password (if security is enabled)

# === Server Configuration (Cloud/Remote mode only) ===
PORT=3000                    # HTTP server port
MCP_DOMAIN=http://localhost:3000  # Public-facing domain (used in OAuth URLs)
BIND_HOST=127.0.0.1          # Bind address (use 0.0.0.0 only behind reverse proxy)
CORS_ORIGINS=                # Comma-separated allowed origins (defaults to MCP_DOMAIN)

# === Security ===
ADMIN_SECRET=                # Optional secret for manual client registration
READONLY_MODE=false          # Set to 'true' to disable all write tools
