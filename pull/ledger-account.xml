<?xml version="1.0" encoding="utf-8"?>
<ENVELOPE>
    <HEADER>
        <VERSION>1</VERSION>
        <TALLYREQUEST>Export</TALLYREQUEST>
        <TYPE>Data</TYPE>
        <ID>MyTallyLiveReport</ID>
    </HEADER>
    <BODY>
        <DESC>
            <STATICVARIABLES>
                <SVEXPORTFORMAT>$$SysName:XML</SVEXPORTFORMAT>
                <SVFROMDATE>{fromDate}</SVFROMDATE>
                <SVTODATE>{toDate}</SVTODATE>
                <nunjuck>if targetCompany</nunjuck>
                <SVCURRENTCOMPANY>{{targetCompany | escape}}</SVCURRENTCOMPANY>
                <nunjuck>endif</nunjuck>
            </STATICVARIABLES>
            <TDL>
                <TDLMESSAGE>
                    <REPORT NAME="MyTallyLiveReport">
                        <FORMS>MyForm</FORMS>
                    </REPORT>
                    <FORM NAME="MyForm">
                        <PARTS>MyPart01</PARTS>
                        <XMLTAG>DATA</XMLTAG>
                    </FORM>
                    <PART NAME="MyPart01">
                        <LINES>MyLine01,MyLineOp</LINES>
                        <REPEAT>MyLine01 : MyCollection</REPEAT>
                        <SCROLLED>Vertical</SCROLLED>
                    </PART>
                    <LINE NAME="MyLine01">
                        <FIELDS>FldDate,FldVoucherType,FldVoucherNumber,FldPartyLedger,FldAmount,FldNarration,FldPartyGSTIN,FldCGSTAmount,FldSGSTAmount,FldIGSTAmount</FIELDS>
                        <XMLTAG>ROW</XMLTAG>
                    </LINE>
                    <LINE NAME="MyLineOp">
                        <FIELDS>FldDateOp,FldVoucherTypeOp,FldVoucherNumberOp,FldPartyLedgerOp,FldAmountOp,FldNarrationOp,FldPartyGSTINOp,FldCGSTAmountOp,FldSGSTAmountOp,FldIGSTAmountOp</FIELDS>
                        <XMLTAG>ROW</XMLTAG>
                    </LINE>
                    <FIELD NAME="FldDate">
                        <SET>$Date</SET>
                        <XMLTAG>F01</XMLTAG>
                    </FIELD>
                    <FIELD NAME="FldVoucherType">
                        <SET>$VoucherTypeName</SET>
                        <XMLTAG>F02</XMLTAG>
                    </FIELD>
                    <FIELD NAME="FldVoucherNumber">
                        <SET>$VoucherNumber</SET>
                        <XMLTAG>F03</XMLTAG>
                    </FIELD>
                    <FIELD NAME="FldPartyLedger">
                        <SET>$PartyLedgerName</SET>
                        <XMLTAG>F04</XMLTAG>
                    </FIELD>
                    <FIELD NAME="FldAmount">
                        <SET>if $$IsDebit:($AllLedgerEntries[1,@@FilterLedgerEqual].Amount) then -$$NumValue:$AllLedgerEntries[1,@@FilterLedgerEqual].Amount else $$NumValue:$AllLedgerEntries[1,@@FilterLedgerEqual].Amount</SET>
                        <XMLTAG>F05</XMLTAG>
                    </FIELD>
                    <FIELD NAME="FldNarration">
                        <SET>$Narration</SET>
                        <XMLTAG>F06</XMLTAG>
                    </FIELD>
                    <FIELD NAME="FldDateOp">
                        <SET>##SVFromDate</SET>
                        <XMLTAG>F01</XMLTAG>
                    </FIELD>
                    <FIELD NAME="FldVoucherTypeOp">
                        <SET>"Opening"</SET>
                        <XMLTAG>F02</XMLTAG>
                    </FIELD>
                    <FIELD NAME="FldVoucherNumberOp">
                        <SET>""</SET>
                        <XMLTAG>F03</XMLTAG>
                    </FIELD>
                    <FIELD NAME="FldPartyLedgerOp">
                        <SET>""</SET>
                        <XMLTAG>F04</XMLTAG>
                    </FIELD>
                    <FIELD NAME="FldAmountOp">
                        <SET>if $$IsDebit:$OpeningBalance:Ledger:"{ledgerName}" then -$$NumValue:$OpeningBalance:Ledger:"{ledgerName}" else $$NumValue:$OpeningBalance:Ledger:"{ledgerName}"</SET>
                        <XMLTAG>F05</XMLTAG>
                    </FIELD>
                    <FIELD NAME="FldNarrationOp">
                        <SET>""</SET>
                        <XMLTAG>F06</XMLTAG>
                    </FIELD>
                    <FIELD NAME="FldPartyGSTIN">
                        <SET>if $$IsEmpty:$PartyGSTIN then $GSTIN:Ledger:$PartyLedgerName else $PartyGSTIN</SET>
                        <XMLTAG>F07</XMLTAG>
                    </FIELD>
                    <FIELD NAME="FldCGSTAmount">
                        <SET>$$StringFindAndReplace:(if $$IsDebit:$AllLedgerEntries[Last,@@FilterCGST].Amount then -$$NumValue:$AllLedgerEntries[Last,@@FilterCGST].Amount else $$NumValue:$AllLedgerEntries[Last,@@FilterCGST].Amount):"(-)":"-"</SET>
                        <XMLTAG>F08</XMLTAG>
                    </FIELD>
                    <FIELD NAME="FldSGSTAmount">
                        <SET>$$StringFindAndReplace:(if $$IsDebit:$AllLedgerEntries[Last,@@FilterSGST].Amount then -$$NumValue:$AllLedgerEntries[Last,@@FilterSGST].Amount else $$NumValue:$AllLedgerEntries[Last,@@FilterSGST].Amount):"(-)":"-"</SET>
                        <XMLTAG>F09</XMLTAG>
                    </FIELD>
                    <FIELD NAME="FldIGSTAmount">
                        <SET>$$StringFindAndReplace:(if $$IsDebit:$AllLedgerEntries[Last,@@FilterIGST].Amount then -$$NumValue:$AllLedgerEntries[Last,@@FilterIGST].Amount else $$NumValue:$AllLedgerEntries[Last,@@FilterIGST].Amount):"(-)":"-"</SET>
                        <XMLTAG>F10</XMLTAG>
                    </FIELD>
                    <FIELD NAME="FldPartyGSTINOp">
                        <SET>""</SET>
                        <XMLTAG>F07</XMLTAG>
                    </FIELD>
                    <FIELD NAME="FldCGSTAmountOp">
                        <SET>""</SET>
                        <XMLTAG>F08</XMLTAG>
                    </FIELD>
                    <FIELD NAME="FldSGSTAmountOp">
                        <SET>""</SET>
                        <XMLTAG>F09</XMLTAG>
                    </FIELD>
                    <FIELD NAME="FldIGSTAmountOp">
                        <SET>""</SET>
                        <XMLTAG>F10</XMLTAG>
                    </FIELD>
                    <COLLECTION NAME="MyCollection">
                        <TYPE>Voucher</TYPE>
                        <FETCH>AllLedgerEntries,Narration,PartyLedgerName,PartyGSTIN</FETCH>
                        <FILTER>FilterLedger,FilterExcludeInventoryVch,FilterExcludeOrderVch,FilterCancelledVouchers,FilterOptionalVouchers</FILTER>
                    </COLLECTION>
                    <SYSTEM TYPE="Formulae" NAME="FilterLedger">NOT $$IsEmpty:$AllLedgerEntries[1,@@FilterLedgerEqual].LedgerName</SYSTEM>
                    <SYSTEM TYPE="Formulae" NAME="FilterLedgerEqual">$LedgerName = "{ledgerName}"</SYSTEM>
                    <SYSTEM TYPE="Formulae" NAME="FilterExcludeInventoryVch">NOT $$IsInventoryVch:$VoucherTypeName</SYSTEM>
                    <SYSTEM TYPE="Formulae" NAME="FilterExcludeOrderVch">NOT $$IsOrderVch:$VoucherTypeName</SYSTEM>
                    <SYSTEM TYPE="Formulae" NAME="FilterCancelledVouchers">NOT $IsCancelled</SYSTEM>
                    <SYSTEM TYPE="Formulae" NAME="FilterOptionalVouchers">NOT $IsOptional</SYSTEM>
                    <SYSTEM TYPE="Formulae" NAME="FilterCGST">$$IsSysNameEqual:$LedgerGSTDutyHead:$$SysName:Central Tax OR $$IsSysNameEqual:$LedgerGSTDutyHead:$$SysName:CGST</SYSTEM>
                    <SYSTEM TYPE="Formulae" NAME="FilterSGST">$$IsSysNameEqual:$LedgerGSTDutyHead:$$SysName:State Tax OR $$IsSysNameEqual:$LedgerGSTDutyHead:$$SysName:SGST OR $$IsSysNameEqual:$LedgerGSTDutyHead:$$SysName:UTGST</SYSTEM>
                    <SYSTEM TYPE="Formulae" NAME="FilterIGST">$$IsSysNameEqual:$LedgerGSTDutyHead:$$SysName:Integrated Tax OR $$IsSysNameEqual:$LedgerGSTDutyHead:$$SysName:IGST</SYSTEM>
                </TDLMESSAGE>
            </TDL>
        </DESC>
    </BODY>
</ENVELOPE>