<?xml version="1.0" encoding="utf-8"?>
<ENVELOPE>
    <HEADER>
        <TALLYREQUEST>Import Data</TALLYREQUEST>
    </HEADER>
    <BODY>
        <IMPORTDATA>
            <REQUESTDESC>
                <REPORTNAME>All Masters</REPORTNAME>
                <STATICVARIABLES>
                    <nunjuck>if targetCompany</nunjuck>
                    <SVCURRENTCOMPANY>{{targetCompany | escape}}</SVCURRENTCOMPANY>
                    <nunjuck>endif</nunjuck>
                </STATICVARIABLES>
            </REQUESTDESC>
            <REQUESTDATA>
                <TALLYMESSAGE xmlns:UDF="TallyUDF">
                    <LEDGER NAME="{{name | escape}}" ACTION="Create">
                        <PARENT>{{parentGroup | escape}}</PARENT>
                        <nunjuck>if openingBalance</nunjuck>
                        <OPENINGBALANCE>{{openingBalance}}</OPENINGBALANCE>
                        <nunjuck>endif</nunjuck>
                        <nunjuck>if mailingName</nunjuck>
                        <MAILINGNAME>{{mailingName | escape}}</MAILINGNAME>
                        <nunjuck>endif</nunjuck>
                        <nunjuck>if gstRegistrationType</nunjuck>
                        <GSTREGISTRATIONTYPE>{{gstRegistrationType | escape}}</GSTREGISTRATIONTYPE>
                        <nunjuck>endif</nunjuck>
                        <nunjuck>if gstin</nunjuck>
                        <PARTYGSTIN>{{gstin | escape}}</PARTYGSTIN>
                        <nunjuck>endif</nunjuck>
                    </LEDGER>
                </TALLYMESSAGE>
            </REQUESTDATA>
        </IMPORTDATA>
    </BODY>
</ENVELOPE>
